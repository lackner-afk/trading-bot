# Kopiere diese Datei nach secrets.env und fülle die Werte aus
# NIEMALS secrets.env ins Repository committen!

# ============================================================
# LIVE-TRADING GUARD (Phase 0+)
# ============================================================
# Um Live-Modus überhaupt zu erlauben, muss diese Variable gesetzt sein:
#   export LIVE_TRADING_ENABLED=1
#   oder mit Datum: export LIVE_TRADING_ENABLED=2026-06-02
#
# Ohne diese Variable wird der Bot Live-Modus blockieren (wird in späteren
# Phasen hart implementiert).

# One Trading API Keys
# https://app.onetrading.com/profile/api-keys
# Hinweis: Öffentliche Marktdaten (WebSocket, Candlesticks) funktionieren OHNE API Key
# API Key wird nur für Order-Execution benötigt
ONETRADING_API_KEY=
ONETRADING_API_SECRET=

# Optional: Webhook für Notifications
WEBHOOK_URL=

# Telegram Bot Notifications
# Bot erstellen via @BotFather, Chat-ID via @userinfobot herausfinden
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
